---
import Base from '../layouts/Base.astro';
---

<Base title="404 — Phil Fugate">
  <section class="not-found">
    <p class="code">404</p>
    <h1>Page not found</h1>
    <p class="msg">The page you're looking for doesn't exist.</p>
    <a href="/" class="back">&larr; Back home</a>
  </section>
</Base>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 0;
  }

  .code {
    font-family: var(--font-mono);
    font-size: 5rem;
    font-weight: 700;
    color: var(--border);
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  h1 { margin-bottom: 0.5rem; }

  .msg {
    color: var(--text-muted);
    margin-bottom: 1.5rem;
  }

  .back {
    font-size: 0.9rem;
    color: var(--accent);
  }
</style>
